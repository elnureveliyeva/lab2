<form action="/gonder"> 
    <h1>Qeydiyyat formu</h1>
    <label for="ad">Ad:</label>
    <input id="ad" name="ad" type="text" placeholder="Adınızı daxil edin">
    
    <br>
    <label for="email">Email:</label>
    <input id="email" name="email" type="email" placeholder="example@mail.com" >

    <br>
    <label for="sifre">Şifrə:</label>
    <input type="password" name="sifre" id="sifre" placeholder="Şifrənizi daxil edin:">

    <br>
    <label for="cins">Cins:</label>
    <select name="cins" id="cins">
    <option value="kişi">Kişi</option>
    <option value="qadın">Qadın</option>
    </select>

    <br>
    <label for="hobbiler">Hobbilər:</label>
    <select name="hobbiler" id="hobbiler">
        <option value="idman">İdman</option>
        <option value="musiqi">Musiqi</option>
        <option value="oyun oynamq">Oyun oynamq</option>
    </select>

    <br>
    <button type="submit"> Göndər</button>
</form>
